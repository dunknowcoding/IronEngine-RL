{
  "runtime": {
    "mode": "simulation",
    "stage": "B"
  },
  "simulator": {
    "dt_s": 0.1,
    "max_steps": 50,
    "enable_noise": true,
    "faults": {
      "sensor_dropout_probability": 0.12,
      "camera_dropout_probability": 0.08,
      "action_lag_steps": 1,
      "observation_delay_steps": 1,
      "collision_bias": 0.1,
      "object_sensor_bias_x": 0.03,
      "object_sensor_bias_y": -0.02,
      "battery_drain_scale": 1.4,
      "wrist_drift_deg": 0.25,
      "intermittent_fault_after_step": 10
    },
    "object_pose": {
      "x": 1.6,
      "y": -0.25
    }
  },
  "vision": {
    "dash_camera_id": "dash_cam_0",
    "claw_camera_id": "claw_cam_0"
  },
  "reward": {
    "progress_scale": 4.5,
    "alignment_scale": 1.8,
    "pregrasp_scale": 1.3,
    "reachability_scale": 0.6,
    "visibility_scale": 0.6,
    "energy_scale": 0.12,
    "battery_margin_scale": 0.15,
    "safety_scale": 3.0,
    "vertical_error_scale": 0.9,
    "success_bonus": 14.0
  },
  "safety": {
    "max_chassis_speed": 0.7,
    "max_turn_rate": 0.6,
    "max_arm_speed": 0.7,
    "collision_stop_threshold": 0.9,
    "stale_observation_stop_steps": 3,
    "connection_required": false,
    "max_arm_extension": 0.85,
    "max_gripper_close": 1.0
  },
  "model_provider": {
    "type": "rule_based"
  },
  "logs": {
    "run_dir": "logs/sim_noisy"
  },
  "future_components": [
    "depth_sensor",
    "force_torque_sensor",
    "wheel_encoder_array",
    "environmental_sensor_pack",
    "lidar_front"
  ]
}
