{
  "framework": {
    "modules": {
      "evaluation": {
        "task": "tabletop_grasp",
        "metrics": [
          "task_performance",
          "boundary_violations"
        ],
        "success_signal": "object_grasped > 0.5"
      },
      "inference_engine": {
        "type": "pytorch_trainable",
        "weights_file": "profiles/model_weights/linear_policy.json",
        "grasp_threshold": 0.35,
        "torch_device": "cpu"
      },
      "update_strategy": {
        "type": "repository_linear_blend",
        "blend_factor": 0.12,
        "success_gain": 0.08
      },
      "agent": {
        "type": "heuristic"
      },
      "repository": {
        "type": "knowledge_repository"
      },
      "boundary_conditions": {
        "enabled": true
      }
    }
  },
  "runtime": {
    "mode": "simulation",
    "stage": "B"
  },
  "simulator": {
    "dt_s": 0.1,
    "max_steps": 30,
    "enable_noise": true,
    "grasp_height_target": 0.18,
    "object_pose": {
      "x": 1.25,
      "y": 0.18
    },
    "faults": {
      "sensor_dropout_probability": 0.08,
      "camera_dropout_probability": 0.05,
      "action_lag_steps": 1,
      "observation_delay_steps": 1,
      "collision_bias": 0.05,
      "battery_drain_scale": 1.2
    }
  },
  "vision": {
    "backend": "replay",
    "dash_camera_id": "dash_cam_custom",
    "claw_camera_id": "claw_cam_custom",
    "replay_file": "profiles/replay_camera/vision_features.json",
    "replay_loop": true
  },
  "reward": {
    "progress_scale": 4.2,
    "alignment_scale": 1.7,
    "pregrasp_scale": 1.3,
    "reachability_scale": 0.6,
    "visibility_scale": 0.5,
    "energy_scale": 0.12,
    "battery_margin_scale": 0.2,
    "safety_scale": 2.8,
    "vertical_error_scale": 0.8,
    "success_bonus": 13.0
  },
  "safety": {
    "max_chassis_speed": 0.7,
    "max_turn_rate": 0.6,
    "max_arm_speed": 0.7,
    "collision_stop_threshold": 0.88,
    "stale_observation_stop_steps": 3,
    "connection_required": false,
    "low_battery_stop_threshold": 0.15,
    "max_arm_extension": 0.85,
    "max_gripper_close": 1.0
  },
  "logs": {
    "run_dir": "logs/framework_customizable"
  },
  "future_components": [
    "depth_sensor",
    "force_torque_sensor",
    "wheel_encoder_array",
    "environmental_sensor_pack",
    "third_camera"
  ]
}
