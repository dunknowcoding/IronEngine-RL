{
  "hardware": {
    "platform": {
      "name": "armsmart_cloud_api_example",
      "type": "armsmart_reference",
      "description": "ARMSmart mock transport paired with an OpenAI-compatible cloud API profile."
    },
    "connection": {
      "backend": "mock",
      "default_mode": "arm",
      "timeout_s": 0.05,
      "read_chunk_size": 256,
      "ble_enabled": true,
      "serial": {
        "port": "COM5",
        "baud_rate": 115200
      },
      "udp": {
        "host": "127.0.0.1",
        "port": 9000,
        "timeout_s": 0.05
      }
    },
    "protocol": {
      "commands": {
        "ping": 1,
        "pong": 2,
        "set_mode_arm": 16,
        "set_mode_car": 17,
        "mode_ack": 18,
        "servo_set": 32,
        "motor_set": 48
      }
    },
    "cameras": {
      "backend": "placeholder",
      "dash": {
        "camera_id": "dash_cam_hw",
        "device_index": 0,
        "role": "dash"
      },
      "claw": {
        "camera_id": "claw_cam_hw",
        "device_index": 1,
        "role": "claw"
      }
    },
    "safety": {
      "max_chassis_speed": 0.5,
      "max_turn_rate": 0.4,
      "max_arm_speed": 0.5,
      "collision_stop_threshold": 0.8,
      "stale_observation_stop_steps": 3,
      "connection_required": true,
      "low_battery_stop_threshold": 0.15,
      "max_arm_extension": 0.85,
      "max_gripper_close": 1.0
    },
    "mock": {
      "active_scenario": "nominal",
      "packets": [],
      "scenarios": {
        "nominal": [
          {
            "timestamp_s": 0.1,
            "connection_alive": 1.0,
            "battery_level": 0.88,
            "collision_risk": 0.04,
            "object_grasped": 0.0,
            "object_dx": 0.44,
            "object_dy": 0.03,
            "arm_height": 0.24,
            "arm_extension": 0.37,
            "claw_alignment": 0.74,
            "gripper_close": 0.14,
            "dash_visibility": 0.85,
            "claw_visibility": 0.55
          }
        ]
      }
    }
  },
  "runtime": {
    "mode": "hardware",
    "stage": "C"
  },
  "llm": {
    "role_contract_file": "SOUL.md",
    "task": {
      "name": "cloth_fold_assist",
      "goal": "Fold the cloth along the center line and place it flat in the destination area.",
      "success_criteria": [
        "align the cloth edges toward the folding line",
        "complete the fold while preserving safety and stability"
      ],
      "constraints": [
        "stay within the configured hardware action scheme",
        "let IronEngine-RL safety policies enforce final motion limits"
      ]
    }
  },
  "model_provider": {
    "type": "cloud_prompt",
    "model": "gpt-4.1-mini",
    "api_base": "https://api.openai.com/v1/chat/completions",
    "api_key_env": "OPENAI_API_KEY",
    "role_contract_file": "SOUL.md",
    "system_prompt": "You are a cloud-hosted reasoning assistant for the ARMSmart robot. Use hardware telemetry and camera visibility to suggest the next safe control phase while letting IronEngine-RL enforce the final safety boundaries.",
    "temperature": 0.2,
    "timeout_s": 20.0
  },
  "evaluation": {
    "task": "hardware_link_validation",
    "metrics": [
      "boundary_violations"
    ]
  },
  "logs": {
    "run_dir": "logs/examples/inference/armsmart_cloud_api"
  }
}
