{
  "hardware": {
    "platform": {
      "name": "custom_robot_reference",
      "type": "custom_hardware",
      "description": "Template for integrating a new hardware platform into IronEngine-RL.",
      "capabilities": {
        "transport_backends": [
          "serial",
          "udp"
        ],
        "observation_fields": [
          "connection_alive",
          "battery_level",
          "collision_risk",
          "object_dx",
          "object_dy",
          "front_range_m",
          "claw_range_m",
          "lidar_front_clearance_m",
          "lidar_left_clearance_m",
          "lidar_right_clearance_m",
          "imu_roll_deg",
          "imu_pitch_deg",
          "imu_yaw_deg",
          "motor_temp_c",
          "ambient_temp_c",
          "humidity_pct",
          "air_quality_index",
          "gripper_pressure_kpa",
          "operator_stop_gesture",
          "gesture_confidence",
          "audio_alarm_score",
          "speech_command_confidence",
          "arm_height",
          "arm_extension",
          "claw_alignment",
          "gripper_close"
        ],
        "camera_roles": [
          "dash",
          "claw",
          "depth_front",
          "depth_wrist"
        ],
        "action_channels": [
          "chassis_forward",
          "chassis_strafe",
          "chassis_turn",
          "arm_lift",
          "arm_extend",
          "wrist_yaw",
          "gripper_close"
        ],
        "safety_features": [
          "collision_threshold",
          "battery_threshold",
          "connection_required",
          "stale_observation_check"
        ],
        "timing": {
          "transport_timeout_s": 0.05,
          "read_chunk_size": 256
        }
      }
    },
    "connection": {
      "backend": "serial",
      "default_mode": "arm",
      "timeout_s": 0.05,
      "read_chunk_size": 256,
      "ble_enabled": false,
      "serial": {
        "port": "COM1",
        "baud_rate": 115200
      },
      "udp": {
        "host": "127.0.0.1",
        "port": 9000,
        "timeout_s": 0.05
      }
    },
    "protocol": {
      "commands": {
        "ping": 1,
        "pong": 2,
        "set_mode_arm": 16,
        "set_mode_car": 17,
        "mode_ack": 18,
        "servo_set": 32,
        "motor_set": 48
      }
    },
    "cameras": {
      "backend": "placeholder",
      "dash": {
        "camera_id": "dash_cam_hw",
        "device_index": 0,
        "role": "dash"
      },
      "claw": {
        "camera_id": "claw_cam_hw",
        "device_index": 1,
        "role": "claw"
      },
      "depth_front": {
        "camera_id": "depth_front_hw",
        "device_index": 2,
        "role": "depth_front"
      },
      "depth_wrist": {
        "camera_id": "depth_wrist_hw",
        "device_index": 3,
        "role": "depth_wrist"
      }
    },
    "sensors": {
      "imu": {
        "enabled": true,
        "frame": "base_link",
        "fields": [
          "imu_roll_deg",
          "imu_pitch_deg",
          "imu_yaw_deg"
        ]
      },
      "lidar": {
        "enabled": false,
        "transport": "udp",
        "fields": [
          "lidar_front_clearance_m",
          "lidar_left_clearance_m",
          "lidar_right_clearance_m"
        ]
      },
      "ranging": {
        "enabled": true,
        "fields": [
          "front_range_m",
          "claw_range_m"
        ]
      },
      "environment": {
        "enabled": false,
        "fields": [
          "ambient_temp_c",
          "humidity_pct",
          "air_quality_index"
        ]
      },
      "pressure": {
        "enabled": false,
        "fields": [
          "gripper_pressure_kpa"
        ]
      },
      "gesture": {
        "enabled": false,
        "fields": [
          "operator_stop_gesture",
          "gesture_confidence"
        ]
      },
      "audio": {
        "enabled": false,
        "fields": [
          "audio_alarm_score",
          "speech_command_confidence"
        ]
      },
      "thermal": {
        "enabled": false,
        "fields": [
          "motor_temp_c",
          "ambient_temp_c"
        ]
      }
    },
    "safety": {
      "max_chassis_speed": 0.5,
      "max_turn_rate": 0.4,
      "max_arm_speed": 0.5,
      "collision_stop_threshold": 0.8,
      "stale_observation_stop_steps": 3,
      "connection_required": true,
      "low_battery_stop_threshold": 0.15,
      "front_range_stop_threshold_m": 0.18,
      "motor_temp_warn_threshold_c": 70.0,
      "air_quality_warn_threshold": 180.0,
      "max_arm_extension": 0.85,
      "max_gripper_close": 1.0
    },
    "mock": {
      "active_scenario": "nominal",
      "packets": [],
      "scenarios": {
        "nominal": []
      }
    }
  },
  "runtime": {
    "mode": "hardware",
    "stage": "C"
  },
  "model_provider": {
    "type": "linear_policy",
    "weights_file": "profiles/model_weights/linear_policy.json",
    "grasp_threshold": 0.35
  },
  "evaluation": {
    "task": "hardware_link_validation",
    "metrics": [
      "boundary_violations"
    ]
  },
  "logs": {
    "run_dir": "logs/examples/hardware/custom_robots/template"
  }
}
