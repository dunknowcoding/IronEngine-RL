{
  "hardware": {
    "platform": {
      "name": "multi_sensor_guarded",
      "type": "custom_hardware",
      "description": "Mock-safe multi-sensor example with explicit sensor-health evaluation and guard-policy safety reactions.",
      "capabilities": {
        "transport_backends": [
          "mock",
          "serial",
          "udp"
        ],
        "observation_fields": [
          "connection_alive",
          "battery_level",
          "collision_risk",
          "object_dx",
          "object_dy",
          "arm_height",
          "arm_extension",
          "claw_alignment",
          "gripper_close",
          "front_range_m",
          "claw_range_m",
          "lidar_front_clearance_m",
          "imu_roll_deg",
          "imu_pitch_deg",
          "imu_yaw_deg",
          "motor_temp_c",
          "ambient_temp_c",
          "humidity_pct",
          "air_quality_index",
          "gripper_pressure_kpa",
          "operator_stop_gesture",
          "gesture_confidence",
          "audio_alarm_score"
        ],
        "camera_roles": [
          "dash",
          "claw",
          "depth_front"
        ],
        "action_channels": [
          "chassis_forward",
          "chassis_strafe",
          "chassis_turn",
          "arm_lift",
          "arm_extend",
          "wrist_yaw",
          "gripper_close"
        ],
        "safety_features": [
          "collision_threshold",
          "battery_threshold",
          "connection_required",
          "stale_observation_check",
          "front_range_threshold",
          "gesture_stop",
          "air_quality_warning",
          "temperature_warning"
        ],
        "timing": {
          "transport_timeout_s": 0.05,
          "read_chunk_size": 256
        }
      }
    },
    "connection": {
      "backend": "mock",
      "default_mode": "arm",
      "timeout_s": 0.05,
      "read_chunk_size": 256,
      "ble_enabled": false
    },
    "protocol": {
      "commands": {
        "ping": 1,
        "pong": 2,
        "set_mode_arm": 16,
        "servo_set": 32,
        "motor_set": 48
      }
    },
    "cameras": {
      "backend": "placeholder",
      "dash": {
        "camera_id": "dash_cam_guarded",
        "device_index": 0,
        "role": "dash"
      },
      "claw": {
        "camera_id": "claw_cam_guarded",
        "device_index": 1,
        "role": "claw"
      },
      "depth_front": {
        "camera_id": "depth_front_guarded",
        "device_index": 2,
        "role": "depth_front"
      }
    },
    "sensors": {
      "imu": {
        "enabled": true,
        "fields": ["imu_roll_deg", "imu_pitch_deg", "imu_yaw_deg"]
      },
      "lidar": {
        "enabled": true,
        "fields": ["lidar_front_clearance_m"]
      },
      "ranging": {
        "enabled": true,
        "fields": ["front_range_m", "claw_range_m"]
      },
      "environment": {
        "enabled": true,
        "fields": ["motor_temp_c", "ambient_temp_c", "humidity_pct", "air_quality_index"]
      },
      "pressure": {
        "enabled": true,
        "fields": ["gripper_pressure_kpa"]
      },
      "gesture": {
        "enabled": true,
        "fields": ["operator_stop_gesture", "gesture_confidence"]
      },
      "audio": {
        "enabled": true,
        "fields": ["audio_alarm_score"]
      }
    },
    "safety": {
      "max_chassis_speed": 0.45,
      "max_turn_rate": 0.35,
      "max_arm_speed": 0.45,
      "collision_stop_threshold": 0.78,
      "stale_observation_stop_steps": 3,
      "connection_required": true,
      "low_battery_stop_threshold": 0.18,
      "front_range_stop_threshold_m": 0.2,
      "motor_temp_warn_threshold_c": 65.0,
      "air_quality_warn_threshold": 150.0,
      "max_arm_extension": 0.82,
      "max_gripper_close": 1.0
    },
    "mock": {
