  "runtime": {
    "mode": "hardware",
    "stage": "C"
  },
  "model_provider": {
    "type": "linear_policy",
    "weights_file": "profiles/model_weights/linear_policy.json"
  },
  "agent": {
    "type": "heuristic"
  },
  "boundary_conditions": {
    "type": "custom_plugin",
    "plugin": {
      "module_path": "user_modules.examples.safety.multi_sensor_guard_policy:MultiSensorGuardSafetyPolicy"
    },
    "front_range_stop_threshold_m": 0.2,
    "stop_gesture_threshold": 0.5,
    "gesture_confidence_threshold": 0.7,
    "air_quality_warn_threshold": 150.0,
    "motor_temp_warn_threshold_c": 65.0,
    "contract": {
      "observation_fields": [
        "connection_alive",
        "battery_level",
        "collision_risk",
        "front_range_m",
        "air_quality_index",
        "motor_temp_c",
        "operator_stop_gesture",
        "gesture_confidence"
      ]
    }
  },
  "evaluation": {
    "task": {
      "name": "hardware_link_validation",
      "contract": {
        "observation_fields": [
          "connection_alive",
          "battery_level",
          "collision_risk",
          "front_range_m",
          "air_quality_index"
        ],
        "camera_roles": ["dash", "claw", "depth_front"]
      }
    },
    "metrics": [
      "boundary_violations",
      {
        "type": "custom_plugin",
        "plugin": {
          "module_path": "user_modules.examples.metrics.sensor_health_metric:SensorHealthMetric"
        },
        "front_range_alert_threshold_m": 0.25,
        "air_quality_alert_threshold": 150.0,
        "stop_gesture_threshold": 0.5
      }
    ]
  },
  "action_scheme": {
    "name": "multi_sensor_guard_schedule",
    "command_channels": [
      "chassis_forward",
      "chassis_strafe",
      "chassis_turn",
      "arm_lift",
      "arm_extend",
      "wrist_yaw",
      "gripper_close"
    ],
    "feedback_fields": [
      "connection_alive",
      "battery_level",
      "collision_risk",
      "front_range_m",
      "lidar_front_clearance_m",
      "imu_yaw_deg",
      "motor_temp_c",
      "air_quality_index",
      "operator_stop_gesture",
      "gesture_confidence",
      "audio_alarm_score"
    ],
    "result_fields": [
      "reward.total",
      "reward.components",
      "done",
      "info"
    ],
    "schedule_notes": [
      "stop motion when front range or operator stop gesture indicates a safety breach",
      "treat air quality and motor temperature as warning signals before they become hard faults"
    ]
  },
  "logs": {
    "run_dir": "logs/examples/hardware/custom_robots/multi_sensor_guarded"
  }
}