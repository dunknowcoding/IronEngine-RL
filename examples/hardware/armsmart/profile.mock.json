          "battery_level": 0.91,
          "collision_risk": 0.08,
          "object_grasped": 0.0,
          "object_dx": 0.42,
          "object_dy": 0.05,
          "imu_roll_deg": 4.2,
          "imu_pitch_deg": -1.8,
          "imu_yaw_deg": 10.6,
          "arm_height": 0.22,
          "arm_extension": 0.32,
          "claw_alignment": 0.73,
          "gripper_close": 0.18,
          "dash_visibility": 0.81,
          "claw_visibility": 0.47
        }
      ],
      "scenarios": {
        "nominal": [
          {
            "timestamp_s": 0.1,
            "connection_alive": 1.0,
            "battery_level": 0.92,
            "collision_risk": 0.05,
            "object_grasped": 0.0,
            "object_dx": 0.56,
            "object_dy": 0.08,
            "imu_roll_deg": 4.5,
            "imu_pitch_deg": -2.0,
            "imu_yaw_deg": 11.0,
