      }
    }
  },
  "runtime": {
    "mode": "hardware",
    "stage": "C"
  },
  "model_provider": {
    "type": "linear_policy",
    "weights_file": "profiles/model_weights/linear_policy.json",
    "grasp_threshold": 0.35
  },
  "evaluation": {
    "task": "hardware_link_validation",
    "metrics": [
      "boundary_violations"
    ]
  },
  "logs": {
    "run_dir": "logs/examples/hardware/armsmart/mock"
  }
